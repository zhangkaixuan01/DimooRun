DIMOORUN_RUNTIME_MODE=production
DIMOORUN_ENVIRONMENT=local-compose
DIMOORUN_NATIVE_RUNTIME_STORE=sqlalchemy
DIMOORUN_CONSOLE_ENABLED=true
DIMOORUN_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
DIMOORUN_TRACING_ENABLED=false

DATABASE_URL=postgresql+psycopg://dimoorun:dimoorun@postgres:5432/dimoorun
REDIS_URL=redis://redis:6379/0

OBJECT_STORE_ENDPOINT_URL=http://minio:9000
OBJECT_STORE_BUCKET=dimoorun-artifacts
OBJECT_STORE_ACCESS_KEY=dimoorun
OBJECT_STORE_SECRET_KEY=dimoorun-dev-secret

VITE_DIMOORUN_API_BASE_URL=http://localhost:8000
VITE_DIMOORUN_TENANT_ID=tenant_1
VITE_DIMOORUN_PROJECT_ID=project_1
VITE_DIMOORUN_API_KEY=replace-with-local-dev-key
