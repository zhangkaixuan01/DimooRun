# Runtime mode controls dev conveniences, not the database choice.
# dev: enables local helpers such as auto table creation and the dev API key.
# production/enterprise: use real infrastructure and stricter cookie settings.
DIMOORUN_RUNTIME_MODE=dev
DIMOORUN_ENVIRONMENT=local

# Native runtime store used when running services directly from this .env.
# Docker Compose overrides this to sqlalchemy so runtime state is stored in Postgres.
DIMOORUN_NATIVE_RUNTIME_STORE=memory

# Console and CORS settings for local browser development.
DIMOORUN_CONSOLE_ENABLED=true
DIMOORUN_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost:8080
DIMOORUN_TRACING_ENABLED=false

# Dev-only bearer key. This is accepted only when DIMOORUN_RUNTIME_MODE=dev.
DIMOORUN_DEV_API_KEY=dev-local-key

# Initial console operator. Change the password before sharing any environment.
DIMOORUN_BOOTSTRAP_ADMIN_EMAIL=admin@local.dimoorun
DIMOORUN_BOOTSTRAP_ADMIN_PASSWORD=admin12345
DIMOORUN_BOOTSTRAP_ADMIN_NAME=Bootstrap Admin

# Default organization scope seeded by init_db and used by bootstrap admin.
DIMOORUN_DEFAULT_TENANT_ID=tenant_1
DIMOORUN_DEFAULT_TENANT_NAME=Default Tenant
DIMOORUN_DEFAULT_PROJECT_ID=project_1
DIMOORUN_DEFAULT_PROJECT_NAME=Default Project
DIMOORUN_DEFAULT_ENVIRONMENT=local

# Direct local startup defaults.
# When using:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
# these are overridden inside containers:
#   DATABASE_URL -> postgresql+psycopg://dimoorun:dimoorun@postgres:5432/dimoorun
#   REDIS_URL    -> redis://redis:6379/0
#   DIMOORUN_NATIVE_RUNTIME_STORE -> sqlalchemy
DATABASE_URL=sqlite:///./data/dimoorun.db
REDIS_URL=redis://localhost:6379/0
DIMOORUN_CONSOLE_ACCESS_TOKEN_TTL_SECONDS=43200

# Object storage. Docker Compose overrides the endpoint to http://minio:9000.
OBJECT_STORE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORE_BUCKET=dimoorun-artifacts
OBJECT_STORE_ACCESS_KEY=dimoorun
OBJECT_STORE_SECRET_KEY=dimoorun-dev-secret

# Frontend build/dev variables. The browser uses 127.0.0.1 because it runs outside Docker.
VITE_DIMOORUN_API_BASE_URL=http://127.0.0.1:8000
VITE_DIMOORUN_DEMO_MODE=false
VITE_DIMOORUN_LOGIN_EMAIL=admin@local.dimoorun
